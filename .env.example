# Copy this to .env and fill in your keys

# ── Required ──────────────────────────────────────────────
GROQ_API_KEY=gsk_your_key_here
COGNEE_API_KEY=your_cognee_cloud_key_here

# ── Cognee Cloud ───────────────────────────────────────────
COGNEE_CLOUD_BASE=https://your-tenant.aws.cognee.ai

# ── Backend ────────────────────────────────────────────────
PORT=8000

# Data directory for incidents.json (Railway: set to /data after mounting a volume)
DATA_DIR=./data

# CORS — comma-separated list of allowed frontend origins
# Add your Vercel URL here for production: https://runbook-os.vercel.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── LLM models ─────────────────────────────────────────────
SYNTHESIS_LLM_MODEL=llama-3.3-70b-versatile

# ── Frontend (set in Vercel dashboard for production) ──────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/events
# Production values:
# NEXT_PUBLIC_API_URL=https://<your-railway-app>.railway.app
# NEXT_PUBLIC_WS_URL=wss://<your-railway-app>.railway.app/ws/events
